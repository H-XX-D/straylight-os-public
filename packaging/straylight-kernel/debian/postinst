#!/bin/bash
set -e

MODULES="vpu hypervisor scheduler entropy enclave"
VERSION="1.0.0"

KERNELS=""
for module_dir in /lib/modules/*; do
    [ -d "${module_dir}/build" ] || continue
    KERNELS="${KERNELS} $(basename "${module_dir}")"
done

if [ -z "${KERNELS}" ]; then
    echo "No installed kernel headers found; skipping StrayLight DKMS builds."
    exit 0
fi

for mod in $MODULES; do
    DKMS_NAME="straylight-${mod}"
    dkms add -m "${DKMS_NAME}" -v "${VERSION}" 2>/dev/null || true
    for kver in $KERNELS; do
        if dkms status -m "${DKMS_NAME}" -v "${VERSION}" -k "${kver}" 2>/dev/null | grep -q "installed"; then
            echo "${DKMS_NAME}/${VERSION} already installed for ${kver}, skipping"
            continue
        fi
        echo "Building and installing ${DKMS_NAME}/${VERSION} for ${kver}..."
        dkms build -m "${DKMS_NAME}" -v "${VERSION}" -k "${kver}"
        dkms install -m "${DKMS_NAME}" -v "${VERSION}" -k "${kver}"
    done
done

XDP_NAME="straylight-xdp"

# XDP programs are eBPF objects, not kernel modules. DKMS is used here only
# to validate that the source still builds against the installed headers.
# Runtime BPF objects are shipped by straylight-network in /usr/lib/straylight/bpf.
dkms add -m "${XDP_NAME}" -v "${VERSION}" 2>/dev/null || true
for kver in $KERNELS; do
    if dkms status -m "${XDP_NAME}" -v "${VERSION}" -k "${kver}" 2>/dev/null | grep -q ": built"; then
        echo "${XDP_NAME}/${VERSION} already built for ${kver}, skipping"
        continue
    fi
    echo "Building ${XDP_NAME}/${VERSION} for ${kver}..."
    dkms build -m "${XDP_NAME}" -v "${VERSION}" -k "${kver}"
done

#DEBHELPER#

exit 0
