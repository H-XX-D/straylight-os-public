[Unit]
Description=StrayLight Tensor Compression FUSE Filesystem
Documentation=https://straylight.dev/docs/fuse
After=straylight-bus.service local-fs.target
Requires=straylight-bus.service

[Service]
Type=simple
ExecStart=/usr/bin/straylight-fuse
ExecStop=/bin/fusermount3 -u /var/lib/straylight/tensors
Restart=on-failure
RestartSec=5s
User=root
CapabilityBoundingSet=CAP_SYS_ADMIN
AmbientCapabilities=CAP_SYS_ADMIN
PrivateTmp=true
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
