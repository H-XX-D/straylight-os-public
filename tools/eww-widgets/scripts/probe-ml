#!/usr/bin/env python3
# probe-ml — outputs JSON snapshot of GPU/ML telemetry
# Primary: nvidia-smi CLI (always available if NVIDIA driver is installed)
# Secondary: NVML via pynvml (optional, richer data)
# Tertiary: straylight IPC sockets (alice.sock for inference stats)

import json, os, subprocess, socket, re
from pathlib import Path

# ── nvidia-smi ───────────────────────────────────────────────────────

NVIDIA_SMI_QUERY = (
    "index,name,utilization.gpu,utilization.memory,"
    "memory.used,memory.total,"
    "temperature.gpu,power.draw,power.limit,"
    "clocks.current.graphics,clocks.current.memory,"
    "fan.speed,pstate"
)

def query_nvidia_smi():
    try:
        result = subprocess.run(
            ["nvidia-smi",
             f"--query-gpu={NVIDIA_SMI_QUERY}",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=2
        )
        if result.returncode != 0:
            return []
        gpus = []
        for line in result.stdout.strip().splitlines():
            parts = [p.strip() for p in line.split(",")]
            if len(parts) < 13:
                continue
            def f(idx, default=0.0):
                try:
                    v = parts[idx]
                    return float(v) if v not in ("[N/A]", "N/A", "") else default
                except Exception:
                    return default
            gpus.append({
                "index":         int(f(0)),
                "name":          parts[1],
                "util_pct":      f(2),
                "mem_util_pct":  f(3),
                "mem_used_mb":   f(4),
                "mem_total_mb":  f(5),
                "temp_c":        f(6),
                "power_w":       f(7),
                "power_limit_w": f(8),
                "clock_gfx_mhz": f(9),
                "clock_mem_mhz": f(10),
                "fan_pct":       f(11),
                "pstate":        parts[12] if len(parts) > 12 else "P0",
                "mem_pct":       round(f(4) / max(f(5), 1) * 100, 1),
            })
        return gpus
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return []

def query_rocm_smi():
    """AMD GPU fallback via rocm-smi."""
    try:
        result = subprocess.run(
            ["rocm-smi", "--showuse", "--showtemp", "--showmemuse",
             "--showpower", "--json"],
            capture_output=True, text=True, timeout=2
        )
        if result.returncode != 0:
            return []
        data = json.loads(result.stdout)
        gpus = []
        for card, info in data.items():
            if not card.startswith("card"):
                continue
            gpus.append({
                "index":        int(card[4:]) if card[4:].isdigit() else 0,
                "name":         info.get("Card Series", "AMD GPU"),
                "util_pct":     float(info.get("GPU use (%)", 0)),
                "mem_util_pct": float(info.get("GPU memory use (%)", 0)),
                "mem_used_mb":  0.0,
                "mem_total_mb": 0.0,
                "temp_c":       float(info.get("Temperature (Sensor edge) (C)", 0)),
                "power_w":      float(info.get("Average Graphics Package Power (W)", 0)),
                "power_limit_w":0.0,
                "clock_gfx_mhz":0.0,
                "clock_mem_mhz":0.0,
                "fan_pct":      0.0,
                "pstate":       "N/A",
                "mem_pct":      float(info.get("GPU memory use (%)", 0)),
            })
        return gpus
    except Exception:
        return []

# ── StrayLight inference stats (alice service) ───────────────────────

def query_alice_inference():
    """Ask straylight-alice for GGUF inference telemetry."""
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(0.3)
        sock.connect("/run/straylight/alice.sock")
        req = json.dumps({"method": "inference_stats"}) + "\n"
        sock.sendall(req.encode())
        data = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            data += chunk
            if b"\n" in data:
                break
        sock.close()
        return json.loads(data.decode().strip())
    except Exception:
        return {}

def query_flux_models():
    """Ask straylight-flux for loaded model list."""
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(0.3)
        sock.connect("/run/straylight/flux.sock")
        req = json.dumps({"method": "list_models"}) + "\n"
        sock.sendall(req.encode())
        data = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            data += chunk
            if b"\n" in data:
                break
        sock.close()
        parsed = json.loads(data.decode().strip())
        return parsed.get("models", [])
    except Exception:
        return []

# ── Assemble ─────────────────────────────────────────────────────────

def main():
    gpus = query_nvidia_smi()
    if not gpus:
        gpus = query_rocm_smi()

    alice  = query_alice_inference()
    models = query_flux_models()

    # Summary across all GPUs
    avg_util  = round(sum(g["util_pct"]    for g in gpus) / max(len(gpus), 1), 1) if gpus else 0.0
    avg_temp  = round(sum(g["temp_c"]      for g in gpus) / max(len(gpus), 1), 1) if gpus else 0.0
    total_mem_used  = round(sum(g["mem_used_mb"]  for g in gpus), 1)
    total_mem_total = round(sum(g["mem_total_mb"] for g in gpus), 1)
    total_power     = round(sum(g["power_w"]      for g in gpus), 1)

    out = {
        "gpus": gpus,
        "summary": {
            "count":          len(gpus),
            "avg_util_pct":   avg_util,
            "avg_temp_c":     avg_temp,
            "mem_used_mb":    total_mem_used,
            "mem_total_mb":   total_mem_total,
            "mem_pct":        round(total_mem_used / max(total_mem_total, 1) * 100, 1),
            "total_power_w":  total_power,
        },
        "inference": alice,
        "models":    models,
    }
    print(json.dumps(out))

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        import json as _j, sys as _s
        _j.dump({"gpus": [], "summary": {"count": 0, "avg_util_pct": 0.0, "avg_temp_c": 0.0, "mem_used_mb": 0.0, "mem_total_mb": 0.0, "mem_pct": 0.0, "total_power_w": 0.0}, "inference": {}, "models": [], "_error": str(e)}, _s.stdout)
        print()
