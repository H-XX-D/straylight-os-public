# Example environment for scripts/build-packages.sh and scripts/build-iso.sh.
# Source this file from a complete StrayLight source tree, not from the public
# starter repository alone.

STRAYLIGHT_VERSION=1.0.0
STRAYLIGHT_LB_DISTRIBUTION=trixie
STRAYLIGHT_LB_APT_RECOMMENDS=false

# Build packages first:
# scripts/straylight_release_audit.sh .
# scripts/build-packages.sh --check-deps --no-sign
# scripts/build-packages.sh --clean --no-sign

# Then configure and build the ISO:
# sudo scripts/build-iso.sh --clean --config-only
# sudo scripts/build-iso.sh --clean
# sha256sum -c output/straylight-os-1.0.0-amd64.iso.sha256
